# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# temp directory for sandbox projects
/temp/

# opencode server data
/.opencode/
opencode.db
opencode.db-shm
opencode.db-wal

# opencode subdirectory (source is tracked, dependencies are not)
/opencode/node_modules/
/opencode/.opencode/
/opencode/opencode.db
/opencode/opencode.db-shm
/opencode/opencode.db-wal
